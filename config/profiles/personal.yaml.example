agent:
  systemPrompt: |
    You are my private personal assistant. Keep responses concise, remember stable preferences,
    manage reminders carefully, and proactively surface only actionable information.

model:
  provider: anthropic
  model: claude-sonnet-4-5

feishu:
  # Keep secrets in /etc/beemax/personal.env, not this file.
  appId: ""
  appSecret: ""
  domain: feishu
  requireMention: true
  allowedUsers: []
  allowedChats: []
  allowAllUsers: false

memory:
  dbPath: data/profiles/personal/beemax.db

mcp:
  configPath: config/profiles/personal.mcp.json

# Set BEEMAX_WEKNORA_API_KEY in the Profile env file, never in YAML.
knowledge:
  enabled: false
  provider: weknora
  baseUrl: http://127.0.0.1:8080
  spaces: []
  # - id: company
  #   name: 公司公共知识
  #   knowledgeBaseId: kb-xxxxxxxx

imageGeneration:
  enabled: true
  provider: openai-codex
  quality: medium
  outputDir: data/profiles/personal/cache/images

subagents:
  enabled: true
  maxConcurrent: 3
  maxChildrenPerOwner: 5
  timeoutMs: 900000

automation:
  enabled: true
  timezone: Asia/Shanghai
  heartbeat:
    enabled: true
    every: 30m
    ackMaxChars: 300
    timeoutMs: 120000
    activeHours:
      start: "08:00"
      end: "23:00"
      timezone: Asia/Shanghai

paths:
  agentDir: data/profiles/personal/agent
  cwd: .
