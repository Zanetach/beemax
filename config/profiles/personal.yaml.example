agent:
  systemPrompt: |
    You are my private personal assistant. Keep responses concise, remember stable preferences,
    manage reminders carefully, and proactively surface only actionable information.

model:
  provider: anthropic
  model: claude-sonnet-4-5
  # Custom providers may declare contextWindow and maxTokens here.

gateway:
  artifactSite:
    enabled: true
    # If Caddy is not on PATH, set BEEMAX_ARTIFACT_SITE_COMMAND in the trusted
    # Gateway service/host environment; Profile YAML and Profile .env are rejected.
    # Omit both values to use this Profile's stable loopback port.
    # listen: 127.0.0.1:18789
    # publicBaseUrl: http://127.0.0.1:18789/artifacts

feishu:
  # Keep secrets in /etc/beemax/personal.env, not this file.
  appId: ""
  appSecret: ""
  domain: feishu
  requireMention: true
  allowedUsers: []
  allowedChats: []
  allowAllUsers: false

memory:
  dbPath: data/profiles/personal/beemax.db

mcp:
  configPath: config/profiles/personal.mcp.json

capabilityProviders:
  installation:
    enabled: true
    allowedProviders: [exa-mcporter]

# Set BEEMAX_WEKNORA_API_KEY in the Profile env file, never in YAML.
knowledge:
  enabled: false
  provider: weknora
  baseUrl: http://127.0.0.1:8080
  spaces: []
  # - id: company
  #   name: 公司公共知识
  #   knowledgeBaseId: kb-xxxxxxxx

mediaUnderstanding:
  auxiliaryVisionEnabled: true
  localOcr:
    enabled: true
    # The executable is host-owned via PATH or BEEMAX_LOCAL_OCR_COMMAND.
    # languages: eng+chi_sim
    timeoutMs: 30000

context:
  maxTurnChars: 12000
  maxToolResultTokens: 12000
  compaction:
    enabled: true
    # Optional per-profile overrides; defaults scale with the active model.
    # reserveTokens: 19200
    # keepRecentTokens: 20480

subagents:
  enabled: true
  maxConcurrent: 3
  maxChildrenPerOwner: 5
  timeoutMs: 900000

automation:
  enabled: true
  timezone: Asia/Shanghai
  heartbeat:
    enabled: true
    every: 30m
    ackMaxChars: 300
    timeoutMs: 120000
    activeHours:
      start: "08:00"
      end: "23:00"
      timezone: Asia/Shanghai

paths:
  agentDir: data/profiles/personal/agent
  cwd: .
