# BeeMax Agent config. Copy to config/beemax.yaml, or use env vars.
# Env vars take precedence over this file.
# Web search uses one of: TAVILY_API_KEY, BRAVE_SEARCH_API_KEY, SEARXNG_URL.

model:
  provider: anthropic
  model: claude-sonnet-4-5
  # apiKey: sk-...         # or set BEEMAX_API_KEY / ANTHROPIC_API_KEY
  # For provider: custom, declare the actual limits (or use
  # BEEMAX_MODEL_CONTEXT_WINDOW / BEEMAX_MODEL_MAX_TOKENS):
  # contextWindow: 128000
  # maxTokens: 8192

gateway:
  # Immutable, content-addressed links for Manifest integrity-checked HTML/PDF/Word outputs.
  # Install Caddy first. Keep loopback unless an authenticated reverse proxy
  # exposes this route; then set publicBaseUrl to that external URL.
  artifactSite:
    enabled: true
    # If Caddy is not on PATH, set BEEMAX_ARTIFACT_SITE_COMMAND in the trusted
    # Gateway service/host environment; Profile YAML and Profile .env are rejected.
    # Omit both values to use this Profile's stable loopback port.
    # listen: 127.0.0.1:18788
    # publicBaseUrl: http://127.0.0.1:18788/artifacts

feishu:
  appId: cli_xxxxxxxxxxxxx
  appSecret: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
  domain: feishu          # feishu | lark
  requireMention: true    # require @bot in groups
  allowedUsers: ou_xxx,on_xxx   # open_id/user_id/union_id, comma-separated
  allowedChats: ""              # optional chat_id restriction, comma-separated
  allowAllUsers: false          # explicit insecure override for public/dev bots

memory:
  dbPath: data/beemax.db

mcp:
  configPath: config/mcp.json

# Each Provider must be explicitly allowlisted and pass Profile scope, policy,
# integrity, Effect, and post-install health checks before first use.
capabilityProviders:
  installation:
    enabled: true
    allowedProviders: [exa-mcporter]

# WeKnora-backed enterprise knowledge. Keep BEEMAX_WEKNORA_API_KEY in .env.
knowledge:
  enabled: false
  provider: weknora
  baseUrl: http://127.0.0.1:8080
  spaces: []
  # - id: company
  #   name: 公司公共知识
  #   knowledgeBaseId: kb-xxxxxxxx

# Inbound image understanding. Installed Tesseract is discovered automatically;
# any configured chat model declaring image input can serve as auxiliary vision.
mediaUnderstanding:
  auxiliaryVisionEnabled: true
  localOcr:
    enabled: true
    # The executable is host-owned via PATH or BEEMAX_LOCAL_OCR_COMMAND.
    # languages: eng+chi_sim
    timeoutMs: 30000

# Context enrichment and Pi compaction. Omit token values to scale them from
# the selected model's actual context window.
context:
  maxTurnChars: 12000
  # Shared conservative output ceiling for Pi built-ins, BeeMax Tools, and MCP.
  maxToolResultTokens: 12000
  compaction:
    enabled: true
    # reserveTokens: 19200
    # keepRecentTokens: 20480

subagents:
  enabled: true
  maxConcurrent: 3
  maxChildrenPerOwner: 5
  timeoutMs: 900000

automation:
  enabled: true
  timezone: Asia/Shanghai
  heartbeat:
    enabled: true
    every: 30m
    # Optional fixed destination. If omitted, the last authorized DM is used.
    # chatId: oc_xxx
    # userId: on_xxx
    ackMaxChars: 300
    timeoutMs: 120000
    activeHours:
      start: "08:00"
      end: "23:00"
      timezone: Asia/Shanghai

paths:
  agentDir: data/agent
  cwd: .
