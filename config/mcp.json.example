{
  "servers": {
    "filesystem-example": {
      "type": "stdio",
      "command": "/absolute/host/path/to/mcp-filesystem-server",
      "args": ["${MCP_FILESYSTEM_ROOT}"],
      "required": false
    },
    "remote-example": {
      "type": "http",
      "url": "https://mcp.example.com/mcp",
      "headers": {
        "Authorization": "Bearer ${MCP_REMOTE_TOKEN}"
      },
      "required": false
    }
  }
}
